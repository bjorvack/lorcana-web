{
  "name": "@bjorvack/lorcana-web",
  "version": "0.1.0",
  "private": true,
  "description": "Vanilla-TS deck builder with in-browser inference, deployed to GitHub Pages.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
